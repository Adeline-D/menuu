{
  "version": 2,
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)",     "dest": "/api/server.js" },
    { "src": "/search",       "dest": "/api/server.js" },
    { "src": "/suggest-all",  "dest": "/api/server.js" },
    { "src": "/decision",     "dest": "/api/server.js" },
    { "src": "/(.*)",         "dest": "/index.html" }
  ]
}